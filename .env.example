# ═══════════════════════════════════════════════════════════
# Bot de Llamadas Telefónicas - Tacos Aragón
# Copia este archivo a .env y llena tus valores reales.
# NUNCA subas .env al repositorio.
# ═══════════════════════════════════════════════════════════

# ┌─────────────────────────────────────────────────────────┐
# │ SERVIDOR                                                │
# └─────────────────────────────────────────────────────────┘
PORT=3001
NODE_ENV=production
# URL pública de tu servidor (IP o dominio + puerto)
BASE_URL=http://TU_IP_PUBLICA:3001

# ┌─────────────────────────────────────────────────────────┐
# │ TWILIO (Servicio de llamadas telefónicas)              │
# └─────────────────────────────────────────────────────────┘
# Obtén estos valores en: https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ┌─────────────────────────────────────────────────────────┐
# │ GOOGLE CLOUD (Speech-to-Text y Text-to-Speech)         │
# └─────────────────────────────────────────────────────────┘
# Ruta al archivo JSON de credenciales de Google Cloud Service Account
# Descárgalo desde: https://console.cloud.google.com/iam-admin/serviceaccounts
GOOGLE_APPLICATION_CREDENTIALS=/ruta/a/tu/google-credentials.json
GOOGLE_CLOUD_PROJECT_ID=tu-proyecto-id

# Configuración de Text-to-Speech (Voz del bot)
TTS_LANGUAGE_CODE=es-MX
TTS_VOICE_NAME=es-US-Neural2-A
TTS_SPEAKING_RATE=1.0
TTS_PITCH=0.0

# Configuración de Speech-to-Text (Transcripción)
STT_LANGUAGE_CODE=es-MX
STT_ENCODING=MULAW
STT_SAMPLE_RATE_HERTZ=8000

# ┌─────────────────────────────────────────────────────────┐
# │ GOOGLE GEMINI (Inteligencia Artificial)                │
# └─────────────────────────────────────────────────────────┘
# Obtén tu API key en: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy_TU_CLAVE_AQUI
GEMINI_MODEL=gemini-2.5-flash

# ┌─────────────────────────────────────────────────────────┐
# │ LOYVERSE (Sistema de punto de venta)                   │
# └─────────────────────────────────────────────────────────┘
# Opcional — si no se pone aquí, el bot lee de datos/loyverse_token.txt
# LOYVERSE_ACCESS_TOKEN=tu_token_loyverse
# LOYVERSE_STORE_ID=tu_uuid_de_tienda
